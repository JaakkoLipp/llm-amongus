# Copy to .env (or export) to enable each provider. Any subset works; players
# whose provider is unconfigured fall back to the offline heuristic agent.

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter (access many models through one OpenAI-compatible endpoint)
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_REFERER=https://among-llms.local

# Ollama (local; no key needed — just have `ollama serve` running)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Defaults
# AMONGLLM_DEFAULT_MODEL=claude:claude-opus-4-8
# AMONGLLM_EVENT_DELAY=0.4
